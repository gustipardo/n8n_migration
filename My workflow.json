      "id": "4840429f-4cc9-4bdb-ac79-343895ced1e7",
      "name": "ML API - Obtener Orden",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        144,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "// =============================================\n// CONFIGURACIÓN - EDITÁ ESTE VALOR\n// =============================================\nconst TELEFONO_FIJO = \"+54 11 1234-5678\"; // <-- Cambiá por tu número\n\n// =============================================\n// OBTENER DATOS DE LA ORDEN\n// =============================================\nconst orden = $input.first().json;\nconst nombreCompleto = `${$input.first().json.first_name} ${$input.first().json.last_name}`.trim();\nconst orderId = orden.id;\n\n// =============================================\n// GENERAR PDF PURO EN JAVASCRIPT\n// =============================================\nfunction generarPDF(nombre, telefono) {\n  const escapar = (str) => str\n    .replace(/\\\\/g, '\\\\\\\\')\n    .replace(/\\(/g, '\\\\(')\n    .replace(/\\)/g, '\\\\)');\n\n  const titulo = escapar('Gracias por tu compra');\n  const linea1 = escapar(`Hola ${orden.first_name} ,`);\n  const linea2 = escapar('gracias por tu compra.');\n  const linea3 = escapar('Por cualquier inconveniente te podes');\n  const linea4 = escapar('comunicar con nosotros a traves de este numero:');\n  const linea5 = escapar(telefono);\n\n  const contenido = [\n    'BT',\n    '/F1 20 Tf',\n    '50 780 Td',\n    `(${titulo}) Tj`,\n    '/F1 13 Tf',\n    '0 -60 Td',\n    `(${linea1}) Tj`,\n    '0 -25 Td',\n    `(${linea2}) Tj`,\n    '0 -50 Td',\n    `(${linea3}) Tj`,\n    '0 -22 Td',\n    `(${linea4}) Tj`,\n    '/F1 15 Tf',\n    '0 -35 Td',\n    `(${linea5}) Tj`,\n    'ET'\n  ].join('\\n') + '\\n';\n\n  const streamBytes = Buffer.from(contenido, 'utf8');\n  const streamLen = streamBytes.length;\n\n  const obj1 = Buffer.from('1 0 obj\\n<< /Type /Catalog /Pages 2 0 R >>\\nendobj\\n', 'utf8');\n  const obj2 = Buffer.from('2 0 obj\\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\\nendobj\\n', 'utf8');\n  const obj3 = Buffer.from('3 0 obj\\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Contents 4 0 R /Resources << /Font << /F1 5 0 R >> >> >>\\nendobj\\n', 'utf8');\n  const obj4 = Buffer.from(`4 0 obj\\n<< /Length ${streamLen} >>\\nstream\\n${contenido}\\nendstream\\nendobj\\n`, 'utf8');\n  const obj5 = Buffer.from('5 0 obj\\n<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>\\nendobj\\n', 'utf8');\n\n  const header = Buffer.from('%PDF-1.4\\n', 'utf8');\n\n  const offsets = [];\n  let pos = header.length;\n  for (const obj of [obj1, obj2, obj3, obj4, obj5]) {\n    offsets.push(pos);\n    pos += obj.length;\n  }\n\n  const xrefOffset = pos;\n\n  let xrefStr = 'xref\\n0 6\\n';\n  xrefStr += '0000000000 65535 f \\n';\n  xrefStr += String(offsets[0]).padStart(10, '0') + ' 00000 n \\n';\n  xrefStr += String(offsets[1]).padStart(10, '0') + ' 00000 n \\n';\n  xrefStr += String(offsets[2]).padStart(10, '0') + ' 00000 n \\n';\n  xrefStr += String(offsets[3]).padStart(10, '0') + ' 00000 n \\n';\n  xrefStr += String(offsets[4]).padStart(10, '0') + ' 00000 n \\n';\n\n  const trailer = Buffer.from(\n    xrefStr +\n    'trailer\\n<< /Size 6 /Root 1 0 R >>\\n' +\n    `startxref\\n${xrefOffset}\\n%%EOF`,\n    'utf8'\n  );\n\n  const pdfBuffer = Buffer.concat([header, obj1, obj2, obj3, obj4, obj5, trailer]);\n  return pdfBuffer.toString('base64');\n}\n\n// =============================================\n// GENERAR Y RETORNAR\n// =============================================\nconst pdfBase64 = generarPDF(nombreCompleto, TELEFONO_FIJO);\n\nreturn [{\n  json: {\n    success: true,\n    orden_id: orderId,\n    comprador_nombre: nombreCompleto,\n    pdf_filename: `gracias_${nombreCompleto.replace(/ /g, '_')}_orden_${orderId}.pdf`,\n    pdf_base64: pdfBase64,\n    mensaje: `PDF generado exitosamente para ${nombreCompleto}`\n  }\n}];"
      },
