      "parameters": {
        "jsCode": "// Solo calculamos el mes anterior como referencia\nconst now = new Date();\nconst firstDayLastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1);\nconst year = firstDayLastMonth.getFullYear();\nconst month = String(firstDayLastMonth.getMonth() + 1).padStart(2, '0');\nconst monthNames = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];\nconst monthName = monthNames[firstDayLastMonth.getMonth()];\nconst referenceMonth = `${year}-${month}`;\n\nreturn [{ json: { referenceMonth, year, month, monthName } }];;"
