      "parameters": {
        "jsCode": "// Normaliza cada factura en una fila lista para Google Sheets\nconst raw = $input.first().json;\nconst docs = Array.isArray(raw) ? raw : (raw.results || raw.documents || []);\n\nif (!docs.length) {\n  throw new Error('No se encontraron facturas para este período.');\n}\n\nreturn docs.map(doc => ({\n  json: {\n    numero_factura:   doc.document_id       || doc.id             || '',\n    tipo:             doc.document_type     || 'BILL',\n    fecha:            doc.date_created      || doc.date           || '',\n    fecha_vencimiento:doc.due_date          || '',\n    estado:           doc.status            || '',\n    moneda:           doc.currency_id       || 'ARS',\n    subtotal:         doc.amount            || doc.subtotal       || 0,\n    iva:              doc.tax_amount        || doc.iva            || 0,\n    total:            doc.total_amount      || doc.total          || 0,\n    descripcion:      doc.description       || '',\n    orden_id:         doc.order_id          || '',\n    periodo:          $('Calcular Período Anterior').first().json.periodKey\n  }\n}));"
      },
